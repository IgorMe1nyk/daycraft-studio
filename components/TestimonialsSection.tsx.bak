/* ────────────────────────────────────────────────────────────────────────────
   BACKUP — Testimonials / "What clients say" section.

   This file is paused (extension `.tsx.bak`) so Next.js and TypeScript do not
   compile it. The component is ready to drop back in once you have real
   client testimonials to show.

   HOW TO RE-ENABLE
   ────────────────
   1. Rename this file to `components/testimonials.tsx` (drop the `.bak` and
      the `Section` suffix). You can do this from the file explorer or with:

         Rename-Item components/TestimonialsSection.tsx.bak components/testimonials.tsx

   2. In `app/page.tsx`, import and render it again. A natural spot is after
      About and before Contact:

         import Testimonials from "@/components/testimonials";

         <About />
         <Testimonials />   {/* <- add back where you want it */}
         <Contact />

   3. Replace the placeholder entries in the `testimonials` array below
      with real client quotes (see the type definitions and TODO comment).

   The original component code follows.
   ──────────────────────────────────────────────────────────────────────────── */

"use client";

import { motion } from "framer-motion";
import { SectionHeading } from "./ui/section-heading";

const easeOut = [0.22, 1, 0.36, 1] as const;

/**
 * TODO: Replace placeholders with real testimonials.
 * Each testimonial needs: quote, name, business, optional photo path.
 * Drop a client photo at /public/clients/<name>.jpg, then replace the
 * gradient avatar block with the commented <Image /> example.
 */
type Testimonial = {
  kind: "real";
  quote: string;
  name: string;
  business: string;
  photo?: string;
};
type Placeholder = { kind: "placeholder" };
type Item = Testimonial | Placeholder;

const testimonials: Item[] = [
  {
    kind: "real",
    // Sample testimonial — styled like the real ones will be. Swap when ready.
    quote:
      "We had a brand-new site live in under a week. It looks like the kind of place you'd actually want to eat at — which is exactly the point.",
    name: "Sample Client",
    business: "Sample Restaurant, Montclair NJ",
  },
  { kind: "placeholder" },
  { kind: "placeholder" },
];

export default function Testimonials() {
  return (
    <section
      id="testimonials"
      className="relative bg-paleBlue/50 py-24 lg:py-32 border-y border-charcoal/[0.04]"
    >
      <div className="mx-auto max-w-6xl px-6 lg:px-8">
        <SectionHeading eyebrow="Testimonials" title="What clients say" />

        <div className="mt-16 grid md:grid-cols-3 gap-6 lg:gap-8">
          {testimonials.map((t, i) =>
            t.kind === "placeholder" ? (
              <motion.div
                key={i}
                initial={{ opacity: 0, y: 16 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true, margin: "-80px" }}
                transition={{ duration: 0.6, delay: i * 0.08, ease: easeOut }}
                className="rounded-2xl border border-dashed border-charcoal/15 bg-cream/40 p-8 flex items-center justify-center text-warmGray/70 text-sm min-h-[260px]"
              >
                {/* TODO: Add a real testimonial card here, mirroring the one to the left. */}
                Testimonial coming soon
              </motion.div>
            ) : (
              <motion.figure
                key={i}
                initial={{ opacity: 0, y: 16 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true, margin: "-80px" }}
                transition={{ duration: 0.6, delay: i * 0.08, ease: easeOut }}
                className="rounded-2xl border border-charcoal/[0.08] bg-cream p-8 flex flex-col"
              >
                <blockquote className="text-charcoal text-[17px] leading-relaxed flex-1">
                  <span className="font-serif text-3xl text-accent leading-none mr-0.5 align-[-0.2em]">
                    “
                  </span>
                  {t.quote}
                </blockquote>
                <figcaption className="mt-6 flex items-center gap-3">
                  {/*
                    TODO: Optional client photo — drop file at /public/clients/<name>.jpg and use:
                    <Image src={t.photo!} alt={t.name} width={36} height={36} className="rounded-full object-cover" />
                  */}
                  <div
                    aria-hidden
                    className="size-9 rounded-full bg-gradient-to-br from-[#E8EEF4] to-[#9DB6CD] shrink-0"
                  />
                  <div className="leading-tight">
                    <div className="text-sm font-medium text-charcoal">
                      {t.name}
                    </div>
                    <div className="text-xs text-warmGray mt-0.5">
                      {t.business}
                    </div>
                  </div>
                </figcaption>
              </motion.figure>
            ),
          )}
        </div>
      </div>
    </section>
  );
}
