   The original component code follows.
   ──────────────────────────────────────────────────────────────────────────── */

"use client";

import { motion } from "framer-motion";
import { ArrowUpRight } from "lucide-react";
import { SectionHeading } from "./ui/section-heading";

const easeOut = [0.22, 1, 0.36, 1] as const;

/**
 * TODO: Replace with real projects. For each project, set:
 *   - name:     Business / project name shown beneath the card
 *   - tag:      Business type ("Restaurant", "Salon", etc.)
 *   - href:     Live site URL (or "#" if not live yet)
 *   - image:    /public path to the project screenshot
 *
 * When adding a real image, replace the gradient placeholder block inside
 * the card with:
 *
 *   <Image
 *     src={p.image}
 *     alt={`${p.name} — ${p.tag}`}
 *     fill
 *     sizes="(max-width: 768px) 100vw, 33vw"
 *     className="object-cover transition-transform duration-700 group-hover:scale-[1.03]"
 *   />
 *
 * and `import Image from "next/image";` at the top.
 */
const projects = [
  {
    name: "Project One",
    tag: "Restaurant",
    href: "#",
    gradient: "from-[#E8EEF4] via-[#D4DFEC] to-[#9DB6CD]",
  },
  {
    name: "Project Two",
    tag: "Event",
    href: "#",
    gradient: "from-[#F4ECE3] via-[#E8D9C6] to-[#CDB28F]",
  },
  {
    name: "Project Three",
    tag: "Salon",
    href: "#",
    gradient: "from-[#EFE7F0] via-[#DCD0E0] to-[#B6A2BD]",
  },
];

export default function Portfolio() {
  return (
    <section id="work" className="py-24 lg:py-32">
      <div className="mx-auto max-w-6xl px-6 lg:px-8">
        <SectionHeading
          eyebrow="Work"
          title="Recent work"
          description="A small selection of recent projects."
        />

        <div className="mt-16 grid md:grid-cols-3 gap-6 lg:gap-8">
          {projects.map((p, i) => (
            <motion.a
              key={p.name}
              href={p.href}
              initial={{ opacity: 0, y: 24 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true, margin: "-80px" }}
              transition={{ duration: 0.6, delay: i * 0.08, ease: easeOut }}
              className="group block focus-visible:outline-none"
            >
              <div
                className={`relative aspect-[4/5] rounded-2xl overflow-hidden bg-gradient-to-br ${p.gradient}`}
              >
                {/* TODO: Replace this placeholder block with the Image
                    component shown in the comment at the top of the file. */}
                <div className="absolute inset-0 grid place-items-center">
                  <span className="text-[11px] tracking-[0.18em] uppercase text-charcoal/30">
                    Coming soon
                  </span>
                </div>
                <div className="absolute inset-0 bg-charcoal/0 group-hover:bg-charcoal/[0.04] transition-colors duration-500" />
                <span className="absolute top-5 left-5 text-[10px] tracking-[0.18em] uppercase text-charcoal/70 bg-cream/75 backdrop-blur-sm px-2.5 py-1 rounded-full">
                  {p.tag}
                </span>
              </div>

              <div className="mt-5 flex items-end justify-between">
                <h3 className="text-lg tracking-tight text-charcoal">
                  {p.name}
                </h3>
                <span className="inline-flex items-center gap-1 text-sm text-warmGray group-hover:text-accent transition-colors">
                  View project
                  <ArrowUpRight className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
                </span>
              </div>
            </motion.a>
          ))}
        </div>
      </div>
    </section>
  );
}
